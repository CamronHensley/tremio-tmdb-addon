# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# TMDB API Key (get one free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Netlify Access Token (for Blobs API - get from Netlify dashboard)
NETLIFY_ACCESS_TOKEN=your_netlify_access_token_here

# Netlify Site ID (found in Site Settings > General)
NETLIFY_SITE_ID=your_site_id_here

# Number of movies per genre (default: 30)
# Optional - adjust if you want more or fewer movies per genre
# MOVIES_PER_GENRE=30

# AI Classification (Optional - requires local Ollama server)
# Enable AI-powered genre classification for improved accuracy
AI_ENABLED=false

# Ollama API endpoint (default: http://127.0.0.1:11434/api/generate)
# Change if running Ollama on a different host/port
# AI_ENDPOINT=http://127.0.0.1:11434/api/generate

# AI model to use (default: qwen2.5:7b-instruct)
# Make sure the model is pulled: ollama pull qwen2.5:7b-instruct
# AI_MODEL=qwen2.5:7b-instruct

# Confidence threshold for AI classifications (default: 0.7)
# AI will fallback to rule-based if confidence is below this threshold
# AI_CONFIDENCE_THRESHOLD=0.7
